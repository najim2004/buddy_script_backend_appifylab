# =============================================================================
# HOW TO GENERATE SECURE SECRETS
# -----------------------------------------------------------------------------
# Copy this file to .env and fill in the values before running the app.
#   cp .env.example .env
#
# For any secret key (APP_KEY, JWT_SECRET, SESSION_SECRET, BETTER_AUTH_SECRET)
# generate a cryptographically secure random string using one of these methods:
#
#   Node.js (recommended):
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
#   OpenSSL:
#     openssl rand -hex 32
#
#   OpenSSL (base64):
#     openssl rand -base64 32
#
# Run any of the above in your terminal and paste the output as the value.
# Never commit your actual .env file — only .env.example should be in git.
# =============================================================================


# =============================================================================
#                               Application
# =============================================================================
APP_NAME=fastify-boilerplate
APP_KEY=secret
PORT=4000
APP_URL=http://localhost:${PORT}
CLIENT_APP_URL=http://localhost:3000

# =============================================================================
#                             Security & Auth
# =============================================================================
SESSION_SECRET=secret
JWT_SECRET=secret
JWT_EXPIRY=86400000

BETTER_AUTH_SECRET=better-auth-secret-key-1234567890abcdef
BETTER_AUTH_URL=http://localhost:4000

# =============================================================================
#                                Database
# =============================================================================
DATABASE_URL="postgresql://postgres:root@localhost:5432/backend?schema=public"

# =============================================================================
#                                  Redis
# =============================================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
#                                   Mail
# =============================================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=name@gmail.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=name@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
#                               OAuth — Google
# =============================================================================
GOOGLE_APP_ID=
GOOGLE_APP_SECRET=
GOOGLE_CALLBACK_URL=${APP_URL}/api/auth/google/redirect

# =============================================================================
#                                  Storage
#                          Driver options: local | s3
#       Switch STORAGE_DRIVER to change backends — no code change needed.
# =============================================================================
STORAGE_DRIVER=local

# AWS S3 / S3-compatible (MinIO, Cloudflare R2, etc.)
# Required when STORAGE_DRIVER=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
# AWS_URL=                      # optional: custom public CDN/URL override

# =============================================================================
#                              Payment — Stripe
# =============================================================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXX

# =============================================================================
#                              Payment — PayPal
# =============================================================================
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_API=https://api-m.sandbox.paypal.com

# =============================================================================
#                             System (seed) User
# =============================================================================
SYSTEM_USERNAME=admin
SYSTEM_EMAIL=admin@example.com
SYSTEM_PASSWORD=12345678
